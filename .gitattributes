# Handle line endings automatically for files detected as text
# and leave binary files untouched.
* text=auto

# Explicitly set default behavior for source files
*.py text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.joblib binary


